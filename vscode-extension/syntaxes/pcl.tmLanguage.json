{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "PCL",
  "scopeName": "source.pcl",
  "fileTypes": ["pcl"],
  "patterns": [
    { "include": "#frontmatter" },
    { "include": "#raw-block" },
    { "include": "#comment" },
    { "include": "#block-definition" },
    { "include": "#directive" },
    { "include": "#interpolation" },
    { "include": "#escape" }
  ],
  "repository": {
    "frontmatter": {
      "name": "meta.frontmatter.pcl",
      "begin": "^(---)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.frontmatter.begin.pcl" }
      },
      "end": "^(---)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.frontmatter.end.pcl" }
      },
      "patterns": [
        {
          "match": "^(\\w[\\w-]*)\\s*(:)",
          "captures": {
            "1": { "name": "entity.name.tag.yaml.pcl" },
            "2": { "name": "punctuation.separator.key-value.pcl" }
          }
        },
        {
          "name": "string.unquoted.frontmatter.value.pcl",
          "match": "(?<=:\\s).*$"
        }
      ]
    },

    "raw-block": {
      "name": "markup.raw.block.pcl",
      "begin": "^(\\s*)(@raw)\\s*$",
      "beginCaptures": {
        "2": { "name": "keyword.control.directive.pcl" }
      },
      "end": "^(\\s*)(@end)\\s*$",
      "endCaptures": {
        "2": { "name": "keyword.control.directive.pcl" }
      },
      "contentName": "string.unquoted.raw.pcl"
    },

    "comment": {
      "name": "comment.line.pcl",
      "match": "^\\s*#.*$"
    },

    "block-definition": {
      "name": "meta.block.definition.pcl",
      "match": "^(block)\\s+(\\w[\\w-]*)\\s*(:)",
      "captures": {
        "1": { "name": "keyword.control.block.pcl" },
        "2": { "name": "entity.name.function.block.pcl" },
        "3": { "name": "punctuation.definition.block.pcl" }
      }
    },

    "directive": {
      "patterns": [
        {
          "name": "meta.directive.import.pcl",
          "match": "^(\\s*)(@import)\\s+(\\S+)(?:\\s+(as)\\s+(\\S+))?",
          "captures": {
            "2": { "name": "keyword.control.directive.pcl" },
            "3": { "name": "string.unquoted.path.pcl" },
            "4": { "name": "keyword.operator.as.pcl" },
            "5": { "name": "entity.name.namespace.pcl" }
          }
        },
        {
          "name": "meta.directive.include.pcl",
          "match": "^(\\s*)(@include)\\s+(\\S+)",
          "captures": {
            "2": { "name": "keyword.control.directive.pcl" },
            "3": { "name": "entity.name.function.include.pcl" }
          }
        },
        {
          "name": "meta.directive.if.pcl",
          "match": "^(\\s*)(@if(?:\\s+not)?)\\s+(\\w+)\\s*(:)",
          "captures": {
            "2": { "name": "keyword.control.conditional.pcl" },
            "3": { "name": "variable.other.condition.pcl" },
            "4": { "name": "punctuation.definition.condition.pcl" }
          }
        }
      ]
    },

    "interpolation": {
      "name": "meta.interpolation.pcl",
      "match": "(?<!\\\\)(\\$\\{)([^|}]+)((?:\\|[^}]*)?)?(\\})",
      "captures": {
        "1": { "name": "punctuation.definition.interpolation.begin.pcl" },
        "2": { "name": "variable.other.interpolated.pcl" },
        "3": { "name": "string.unquoted.default.pcl" },
        "4": { "name": "punctuation.definition.interpolation.end.pcl" }
      }
    },

    "escape": {
      "patterns": [
        {
          "name": "constant.character.escape.pcl",
          "match": "\\\\[@#]|\\\\\\$\\{"
        }
      ]
    }
  }
}
